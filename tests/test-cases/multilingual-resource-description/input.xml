          <gmd:title xsi:type="gmd:PT_FreeText_PropertyType">
            <gco:CharacterString>Modèle hydrodynamique 3D d'évolution de l'océan</gco:CharacterString>
            <gmd:PT_FreeText>
              <gmd:textGroup>
                <gmd:LocalisedCharacterString locale="#EN">3D hydrodynamic model for the evolution of the ocean</gmd:LocalisedCharacterString>
              </gmd:textGroup>
            </gmd:PT_FreeText>
          </gmd:title>
